# Target GitHub repo (owner/repo)
BACKLOG_REPO=owner/repo

# Local clone path of the target repo (used as cwd for CLI tools)
BACKLOG_DIR=~/path/to/local/clone

# Path to Claude Code CLI binary
CLAUDE_BIN=claude

# Claude model to use for formatting
CLAUDE_MODEL=sonnet

# Comma-separated valid labels for issues
ISSUE_LABELS=learning,infra,side-project,content,core-skill

# Fallback label when none match (defaults to first of ISSUE_LABELS)
# DEFAULT_LABEL=learning

# Bearer token for API authentication (optional, disabled when unset)
# API_TOKEN=your-secret-token

# Max requests per minute (default: 10)
# RATE_LIMIT=10
